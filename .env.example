# .env.example
# Copy to .env and fill in values for your environment.
# This file is safe to commit. .env is NOT committed (in .gitignore).

# ---------------------------------------------------------------------------
# LLM backend
# On pod:   http://172.29.127.170:8000/v1
# Locally:  http://host.docker.internal:8000/v1  (if vLLM runs on your laptop)
#           or point to any OpenAI-compatible endpoint
# On AWS:   http://<sagemaker-endpoint>/v1  or hosted vLLM EC2 IP
# ---------------------------------------------------------------------------
LLM_BASE_URL=http://host.docker.internal:8000/v1
LLM_MODEL=qwen2.5-14b
LLM_API_KEY=dummy

# ---------------------------------------------------------------------------
# API security (change in production)
# ---------------------------------------------------------------------------
API_SECRET_KEY=dev-secret-change-in-production

# ---------------------------------------------------------------------------
# Upload limits
# ---------------------------------------------------------------------------
MAX_VCF_SIZE_MB=500
