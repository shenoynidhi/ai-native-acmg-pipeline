# .env.docker
# Baked into the Docker image as /app/.env
# These are the container-internal defaults — all overridable at runtime.
# Do NOT put secrets here. Use docker-compose environment: or AWS Secrets Manager.

PYTHONPATH=/app
PYTHONUNBUFFERED=1

VEP_DATA_DIR=/data/vep
DATABASE_DIR=/data/databases
CHROMADB_DIR=/data/chromadb
OUTPUT_DIR=/data/output
REFERENCE_DIR=/data/reference

VEP_BINARY=/opt/vep/src/ensembl-vep/vep
VEP_PERL=/usr/bin/perl
BCFTOOLS_BINARY=/usr/bin/bcftools
SAMTOOLS_BINARY=/usr/bin/samtools
WHATSHAP_BINARY=/usr/local/bin/whatshap

LLM_BASE_URL=http://llm:8000/v1
LLM_MODEL=qwen2.5-14b
LLM_API_KEY=dummy

#REPORT
LAB_NAME=Molsys Private Limited
LAB_CONTACT=genomics@molsys.in
LAB_LOGO_PATH=/workspace/data/acmg-pipeline/assets/logo.png
